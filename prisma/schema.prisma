generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ping {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}

// Simple key-value counter table. Currently used for the homepage
// visit counter (key = "home_visits"). Kept generic so we can pile
// more site-wide counters on top without a schema change.
model SiteStat {
  key       String   @id
  value     BigInt   @default(0)
  updatedAt DateTime @updatedAt
}

enum Region {
  SHONAN
  CHIBA
  SHIZUOKA
  MIYAZAKI
  WORLD
}

model Spot {
  id                Int      @id @default(autoincrement())
  slug              String   @unique

  nameJa            String
  nameEn            String
  nameZh            String?

  region            Region
  latitude          Float
  longitude         Float

  trainAccessible   Boolean  @default(false)
  beginnerFriendly  Boolean  @default(false)
  boardTypes        String[] @default([])

  optimalSwellDir   String?
  offshoreWindDir   String?

  descJa            String?
  descEn            String?
  descZh            String?

  // Specific address / prefecture / country, shown in the card header
  // instead of the generic region chip (which is already visible in
  // the filter tabs). e.g. Kugenuma → 神奈川県 藤沢市, Waikiki →
  // ハワイ・オアフ島. Nullable so we can add it incrementally.
  locationJa        String?
  locationEn        String?
  locationZh        String?

  sortOrder         Int      @default(1000)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cams              Cam[]

  @@index([region])
  @@index([sortOrder])
}

model Cam {
  id                Int      @id @default(autoincrement())
  spotId            Int
  slug              String   @unique

  nameJa            String
  nameEn            String
  nameZh            String?

  youtubeVideoId    String?
  youtubeChannelId  String?

  provider          String   @default("youtube")
  active            Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  spot              Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@index([spotId])
}
